## Contoh Cepat 🔑

Berikut adalah contoh dasar menampilkan teks menggunakan driver FansElectronics_DMD8266:

#include <FansElectronics_DMD8266.h>
// Pastikan Anda menyertakan file font yang kompatibel
#include <fonts/SystemFont5x7.h> 

FansElectronics_DMD8266 dmd;

// Konfigurasi Pin disesuaikan dengan koneksi fisik panel Anda
DmdPins myPins = {16, 5, 4, 0, 2, 14, 15, 13};

void setup() {
    // Inisialisasi: Tipe panel HUB08, 2 Panel Horizontal, 1 Panel Vertikal
    dmd.begin(PANEL_HUB08, 2, 1, myPins); 
    
    // Aktifkan Double Buffer untuk animasi yang mulus tanpa kedipan
    dmd.setDoubleBuffer(true);
    
    // Atur kecerahan layar (0 - 255)
    dmd.setBrightness(200);
    
    // Set font aktif yang digunakan
    // dmd.setFont(SystemFont5x7); 
}

void loop() {
    // Bersihkan buffer kanvas latar belakang
    dmd.clear();
    
    // Gambar teks pada koordinat X=2, Y=0
    dmd.drawText(2, 0, "FansElectronics");
    
    // Tukar buffer gambar belakang ke layar visual utama
    dmd.swapBuffers();
    
    // Tangani pembaruan data layar dan timer latar belakang
    dmd.update();
}

